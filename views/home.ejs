<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">

</head>
<body>
    <h1>Thank you!!</h1>
    <table class="bound">
        <tr >
            <th class="bound">Name</td>
            <th class="bound">Number</td>
        </tr>
        <% for (let Data of result){ %>
            <tr >
                <td class="bound"> <%= Data.Name %> </td>
                <td class="bound"> <%= Data.Marks %> </td>           
                <td>
                    <form action="http://localhost:8080/edit" method="get" >
                        <input type="hidden" name="Name" value="<%= Data.Name %>">
                        <button type="submit">Edit</button> 
                    </form>
                </td>
            </tr>
        <% } %>


    </table>
</body>
</html>